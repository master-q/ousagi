{
  "image": "cuihtlauac/ocaml-devcontainer:latest",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/sliekens/devcontainer-features/codex:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers-extra/features/haskell:2": {
      "ghcVersion": "9.6",
      "cabalVersion": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ocamllabs.ocaml-platform",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.makefile-tools",
        "rust-lang.rust-analyzer",
        "haskell.haskell"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/claude/dot.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/claude/dot.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.claude && sudo apt-get update && sudo apt-get install -y cmake valac libgtk-4-dev libgtk-3-dev libpoppler-glib-dev libgirepository1.0-dev gobject-introspection pkg-config qt6-base-dev qt6-declarative-dev qt6-pdf-dev fonts-noto-color-emoji && opam update && opam install -y lablgtk3 cairo2 && cabal update",
  "containerEnv": {
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8",
    "OPAMYES": "true",
    "GH_TOKEN": "${localEnv:GH_READONLY_TOKEN}"
  }
}
